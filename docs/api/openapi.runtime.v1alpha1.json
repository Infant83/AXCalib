{
  "components": {
    "schemas": {
      "Assessment": {
        "description": "One criterion assessment without a final certification decision.",
        "enum": [
          "met",
          "partially_met",
          "not_met",
          "insufficient_evidence",
          "not_applicable"
        ],
        "title": "Assessment",
        "type": "string"
      },
      "CancelRunResponse": {
        "additionalProperties": false,
        "description": "Acknowledgement of a cooperative cancellation request.",
        "properties": {
          "cancellation_requested": {
            "default": true,
            "title": "Cancellation Requested",
            "type": "boolean"
          },
          "run_id": {
            "title": "Run Id",
            "type": "string"
          },
          "schema_version": {
            "default": "axcalib.api-cancel/v1alpha1",
            "title": "Schema Version",
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/PipelineRunStatus"
          }
        },
        "required": [
          "run_id",
          "status"
        ],
        "title": "CancelRunResponse",
        "type": "object"
      },
      "CompletionDecisionRequest": {
        "additionalProperties": false,
        "description": "Administrator completion command; actor identity comes from auth.",
        "properties": {
          "adjustments": {
            "default": [],
            "items": {
              "$ref": "#/components/schemas/ReviewerAdjustment"
            },
            "title": "Adjustments",
            "type": "array"
          },
          "command": {
            "enum": [
              "accept",
              "not_accept"
            ],
            "title": "Command",
            "type": "string"
          },
          "expected_revision": {
            "minimum": 1.0,
            "title": "Expected Revision",
            "type": "integer"
          },
          "rationale": {
            "maxLength": 4000,
            "minLength": 1,
            "title": "Rationale",
            "type": "string"
          }
        },
        "required": [
          "expected_revision",
          "command",
          "rationale"
        ],
        "title": "CompletionDecisionRequest",
        "type": "object"
      },
      "EvidenceLocator": {
        "additionalProperties": false,
        "description": "Auditable source location with a short allowed excerpt.",
        "properties": {
          "artifact_id": {
            "title": "Artifact Id",
            "type": "string"
          },
          "excerpt": {
            "maxLength": 500,
            "title": "Excerpt",
            "type": "string"
          },
          "locator": {
            "title": "Locator",
            "type": "string"
          },
          "source": {
            "title": "Source",
            "type": "string"
          }
        },
        "required": [
          "artifact_id",
          "locator",
          "excerpt",
          "source"
        ],
        "title": "EvidenceLocator",
        "type": "object"
      },
      "PipelineCatalogResponse": {
        "additionalProperties": false,
        "description": "Deterministic catalog of allowlisted local pipelines.",
        "properties": {
          "pipelines": {
            "items": {
              "$ref": "#/components/schemas/PipelineDescriptor"
            },
            "title": "Pipelines",
            "type": "array"
          },
          "schema_version": {
            "default": "axcalib.api-pipeline-catalog/v1alpha1",
            "title": "Schema Version",
            "type": "string"
          }
        },
        "required": [
          "pipelines"
        ],
        "title": "PipelineCatalogResponse",
        "type": "object"
      },
      "PipelineDescriptor": {
        "additionalProperties": false,
        "description": "Small serializable catalog entry for delivery adapters.",
        "properties": {
          "pipeline_id": {
            "title": "Pipeline Id",
            "type": "string"
          },
          "pipeline_version": {
            "title": "Pipeline Version",
            "type": "string"
          },
          "request_type": {
            "title": "Request Type",
            "type": "string"
          },
          "result_type": {
            "title": "Result Type",
            "type": "string"
          }
        },
        "required": [
          "pipeline_id",
          "pipeline_version",
          "request_type",
          "result_type"
        ],
        "title": "PipelineDescriptor",
        "type": "object"
      },
      "PipelineRunRequest": {
        "additionalProperties": false,
        "description": "Transport options plus one pipeline-specific JSON payload.",
        "properties": {
          "expected_revision": {
            "anyOf": [
              {
                "minimum": 1.0,
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Expected Revision"
          },
          "idempotency_key": {
            "anyOf": [
              {
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Idempotency Key"
          },
          "payload": {
            "additionalProperties": true,
            "title": "Payload",
            "type": "object"
          },
          "run_id": {
            "anyOf": [
              {
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Run Id"
          }
        },
        "required": [
          "payload"
        ],
        "title": "PipelineRunRequest",
        "type": "object"
      },
      "PipelineRunStatus": {
        "description": "Persisted lifecycle of one local pipeline execution.",
        "enum": [
          "prepared",
          "running",
          "succeeded",
          "waiting_human",
          "blocked",
          "stale",
          "retryable_failure",
          "terminal_failure",
          "cancelled"
        ],
        "title": "PipelineRunStatus",
        "type": "string"
      },
      "PipelineRunView": {
        "additionalProperties": false,
        "description": "Filesystem-neutral execution result safe for HTTP delivery.",
        "properties": {
          "attempt": {
            "minimum": 0.0,
            "title": "Attempt",
            "type": "integer"
          },
          "error_code": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Code"
          },
          "output": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Output"
          },
          "pipeline_id": {
            "title": "Pipeline Id",
            "type": "string"
          },
          "pipeline_version": {
            "title": "Pipeline Version",
            "type": "string"
          },
          "replayed": {
            "default": false,
            "title": "Replayed",
            "type": "boolean"
          },
          "run_id": {
            "title": "Run Id",
            "type": "string"
          },
          "schema_version": {
            "default": "axcalib.api-pipeline-run/v1alpha1",
            "title": "Schema Version",
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/PipelineRunStatus"
          },
          "updated_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Updated At"
          }
        },
        "required": [
          "run_id",
          "pipeline_id",
          "pipeline_version",
          "status",
          "attempt"
        ],
        "title": "PipelineRunView",
        "type": "object"
      },
      "Problem": {
        "additionalProperties": false,
        "description": "RFC 9457-shaped error body with AXCalib-stable machine codes.",
        "properties": {
          "code": {
            "title": "Code",
            "type": "string"
          },
          "detail": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Detail"
          },
          "issues": {
            "default": [],
            "items": {
              "$ref": "#/components/schemas/ValidationIssue"
            },
            "title": "Issues",
            "type": "array"
          },
          "status": {
            "title": "Status",
            "type": "integer"
          },
          "title": {
            "title": "Title",
            "type": "string"
          },
          "type": {
            "title": "Type",
            "type": "string"
          }
        },
        "required": [
          "type",
          "title",
          "status",
          "code"
        ],
        "title": "Problem",
        "type": "object"
      },
      "ProjectArtifactView": {
        "additionalProperties": false,
        "description": "Hash metadata safe to return without a deployment-local URI.",
        "properties": {
          "artifact_id": {
            "title": "Artifact Id",
            "type": "string"
          },
          "byte_size": {
            "minimum": 0.0,
            "title": "Byte Size",
            "type": "integer"
          },
          "media_type": {
            "title": "Media Type",
            "type": "string"
          },
          "role": {
            "title": "Role",
            "type": "string"
          },
          "sha256": {
            "title": "Sha256",
            "type": "string"
          }
        },
        "required": [
          "artifact_id",
          "role",
          "media_type",
          "sha256",
          "byte_size"
        ],
        "title": "ProjectArtifactView",
        "type": "object"
      },
      "ProjectCommandResponse": {
        "additionalProperties": false,
        "description": "Filesystem-neutral domain command result.",
        "properties": {
          "allowed_commands": {
            "default": [],
            "items": {
              "type": "string"
            },
            "title": "Allowed Commands",
            "type": "array"
          },
          "dossier_revision": {
            "minimum": 1.0,
            "title": "Dossier Revision",
            "type": "integer"
          },
          "dossier_status": {
            "$ref": "#/components/schemas/ProjectStatus"
          },
          "message": {
            "title": "Message",
            "type": "string"
          },
          "project_id": {
            "title": "Project Id",
            "type": "string"
          },
          "report_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Report Id"
          },
          "schema_version": {
            "default": "axcalib.api-project-command/v1alpha1",
            "title": "Schema Version",
            "type": "string"
          },
          "status": {
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "project_id",
          "status",
          "dossier_status",
          "dossier_revision",
          "message"
        ],
        "title": "ProjectCommandResponse",
        "type": "object"
      },
      "ProjectRegistrationRequest": {
        "additionalProperties": false,
        "description": "Register a staged PPTX without accepting a caller-controlled local path.",
        "properties": {
          "certification_level": {
            "anyOf": [
              {
                "maxLength": 100,
                "minLength": 1,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Certification Level"
          },
          "proposal": {
            "$ref": "#/components/schemas/StagedArtifactRef"
          },
          "review_profile": {
            "anyOf": [
              {
                "pattern": "^[a-z0-9][a-z0-9._-]{2,127}@\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Review Profile"
          },
          "sidecar": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/StagedArtifactRef"
              },
              {
                "type": "null"
              }
            ]
          },
          "title": {
            "maxLength": 300,
            "minLength": 1,
            "title": "Title",
            "type": "string"
          }
        },
        "required": [
          "title",
          "proposal"
        ],
        "title": "ProjectRegistrationRequest",
        "type": "object"
      },
      "ProjectRegistrationResponse": {
        "additionalProperties": false,
        "description": "Filesystem-neutral result of one principal-bound project registration.",
        "properties": {
          "artifact": {
            "$ref": "#/components/schemas/ProjectArtifactView"
          },
          "display_id": {
            "title": "Display Id",
            "type": "string"
          },
          "project_id": {
            "title": "Project Id",
            "type": "string"
          },
          "proposer_org_id": {
            "title": "Proposer Org Id",
            "type": "string"
          },
          "replayed": {
            "default": false,
            "title": "Replayed",
            "type": "boolean"
          },
          "revision": {
            "minimum": 1.0,
            "title": "Revision",
            "type": "integer"
          },
          "schema_version": {
            "default": "axcalib.api-project/v1alpha1",
            "title": "Schema Version",
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/ProjectStatus"
          },
          "title": {
            "title": "Title",
            "type": "string"
          }
        },
        "required": [
          "project_id",
          "display_id",
          "title",
          "status",
          "revision",
          "proposer_org_id",
          "artifact"
        ],
        "title": "ProjectRegistrationResponse",
        "type": "object"
      },
      "ProjectStatus": {
        "enum": [
          "draft",
          "registration_ready",
          "registration_under_review",
          "registration_hitl_pending",
          "registration_approved",
          "registration_rejected",
          "in_progress",
          "completion_ready",
          "completion_approval_pending",
          "completion_registered",
          "completion_under_review",
          "completion_hitl_pending",
          "completion_accepted",
          "completion_not_accepted"
        ],
        "title": "ProjectStatus",
        "type": "string"
      },
      "RegistrationDecisionRequest": {
        "additionalProperties": false,
        "description": "Administrator registration command; actor identity comes from auth.",
        "properties": {
          "adjustments": {
            "default": [],
            "items": {
              "$ref": "#/components/schemas/ReviewerAdjustment"
            },
            "title": "Adjustments",
            "type": "array"
          },
          "command": {
            "enum": [
              "approve",
              "reject"
            ],
            "title": "Command",
            "type": "string"
          },
          "expected_revision": {
            "minimum": 1.0,
            "title": "Expected Revision",
            "type": "integer"
          },
          "rationale": {
            "maxLength": 4000,
            "minLength": 1,
            "title": "Rationale",
            "type": "string"
          }
        },
        "required": [
          "expected_revision",
          "command",
          "rationale"
        ],
        "title": "RegistrationDecisionRequest",
        "type": "object"
      },
      "ReviewerAdjustment": {
        "additionalProperties": false,
        "description": "Criterion-level human correction that never rewrites the Agent report.",
        "properties": {
          "criterion_id": {
            "title": "Criterion Id",
            "type": "string"
          },
          "evidence_refs": {
            "default": [],
            "items": {
              "$ref": "#/components/schemas/EvidenceLocator"
            },
            "title": "Evidence Refs",
            "type": "array"
          },
          "from_assessment": {
            "$ref": "#/components/schemas/Assessment"
          },
          "reason": {
            "maxLength": 2000,
            "minLength": 1,
            "title": "Reason",
            "type": "string"
          },
          "to_assessment": {
            "$ref": "#/components/schemas/Assessment"
          }
        },
        "required": [
          "criterion_id",
          "from_assessment",
          "to_assessment",
          "reason"
        ],
        "title": "ReviewerAdjustment",
        "type": "object"
      },
      "StagedArtifactRef": {
        "additionalProperties": false,
        "description": "Opaque reference to bytes already accepted by a deployment staging service.",
        "properties": {
          "artifact_id": {
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
            "title": "Artifact Id",
            "type": "string"
          },
          "byte_size": {
            "minimum": 1.0,
            "title": "Byte Size",
            "type": "integer"
          },
          "media_type": {
            "maxLength": 200,
            "minLength": 1,
            "title": "Media Type",
            "type": "string"
          },
          "sha256": {
            "pattern": "^[a-f0-9]{64}$",
            "title": "Sha256",
            "type": "string"
          }
        },
        "required": [
          "artifact_id",
          "sha256",
          "byte_size",
          "media_type"
        ],
        "title": "StagedArtifactRef",
        "type": "object"
      },
      "ValidationIssue": {
        "additionalProperties": false,
        "description": "Redacted validation location and code without rejected input values.",
        "properties": {
          "code": {
            "title": "Code",
            "type": "string"
          },
          "location": {
            "title": "Location",
            "type": "string"
          }
        },
        "required": [
          "location",
          "code"
        ],
        "title": "ValidationIssue",
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "summary": "Authenticated HTTP parity for allowlisted AXCalib pipelines",
    "title": "AXCalib Runtime API",
    "version": "v1alpha1"
  },
  "jsonSchemaDialect": "https://json-schema.org/draft/2020-12/schema",
  "openapi": "3.1.0",
  "paths": {
    "/v1/pipelines": {
      "get": {
        "operationId": "listPipelines",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PipelineCatalogResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "401": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            },
            "description": "Structured AXCalib API problem"
          },
          "503": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            },
            "description": "Structured AXCalib API problem"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "List Pipelines"
      }
    },
    "/v1/pipelines/{pipeline_id}/versions/{pipeline_version}/runs": {
      "post": {
        "operationId": "runPipeline",
        "parameters": [
          {
            "in": "path",
            "name": "pipeline_id",
            "required": true,
            "schema": {
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
              "title": "Pipeline Id",
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "pipeline_version",
            "required": true,
            "schema": {
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
              "title": "Pipeline Version",
              "type": "string"
            }
          },
          {
            "in": "header",
            "name": "Idempotency-Key",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Idempotency-Key"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PipelineRunRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PipelineRunView"
                }
              }
            },
            "description": "Successful Response"
          },
          "401": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            },
            "description": "Structured AXCalib API problem"
          },
          "403": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            },
            "description": "Structured AXCalib API problem"
          },
          "404": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            },
            "description": "Structured AXCalib API problem"
          },
          "409": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            },
            "description": "Structured AXCalib API problem"
          },
          "422": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            },
            "description": "Structured AXCalib API problem"
          },
          "503": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            },
            "description": "Structured AXCalib API problem"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "Run Pipeline"
      }
    },
    "/v1/projects": {
      "post": {
        "operationId": "registerProject",
        "parameters": [
          {
            "in": "header",
            "name": "Idempotency-Key",
            "required": true,
            "schema": {
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$",
              "title": "Idempotency-Key",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProjectRegistrationRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectRegistrationResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "401": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            },
            "description": "Structured AXCalib API problem"
          },
          "403": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            },
            "description": "Structured AXCalib API problem"
          },
          "404": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            },
            "description": "Structured AXCalib API problem"
          },
          "409": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            },
            "description": "Structured AXCalib API problem"
          },
          "413": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            },
            "description": "Structured AXCalib API problem"
          },
          "422": {
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/Problem"
                }
              }
            },
            "description": "Structured AXCalib API problem"
          },
          "503": {
            "content": {
